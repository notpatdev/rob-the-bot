DISCORD_TOKEN=
BOT_NAME=Rob
EVENT_NAME=Mother's Day Event

DATABASE_PATH=/opt/rob-the-bot/data/rob_the_bot.sqlite3

# --- Throne tracking (all optional) ---
# How often (seconds) to poll registered Dommes' Throne pages. Default: 60.
# THRONE_POLL_INTERVAL_SECONDS=60
# Delay between Domme requests within a cycle, to avoid hammering Throne. Default: 3.
# THRONE_POLL_PER_DOMME_DELAY_SECONDS=3
# Per-request HTTP timeout. Default: 10.
# THRONE_HTTP_TIMEOUT_SECONDS=10
# User-Agent header to send when scraping. Defaults to a benign realistic UA.
# THRONE_USER_AGENT=

# --- Throne Webhook Integration ---
# Port for the local aiohttp webhook server (bound to 127.0.0.1). Default: 8080.
# THRONE_WEBHOOK_PORT=8080
# Publicly reachable base URL for the webhook server (used to show creators their
# webhook URL on registration). Must include scheme, e.g. https://rob.example.com
# THRONE_WEBHOOK_BASE_URL=
# Ed25519 public key from the Throne developer portal (PEM format, required for
# production). Leave unset only when THRONE_WEBHOOK_REQUIRE_SIGNATURE=false.
# THRONE_PUBLIC_KEY_PEM=
# Set to false to disable signature verification (local testing only).
# THRONE_WEBHOOK_REQUIRE_SIGNATURE=true
# Throne webhook header names — confirm from https://help.throne.com/en/articles/14982436-webhook-integration
# THRONE_WEBHOOK_TIMESTAMP_HEADER=X-Signature-Timestamp
# THRONE_WEBHOOK_SIGNATURE_HEADER=X-Signature-Ed25519
# Signed message format: timestamp_dot_body | timestamp_concat_body | body_only
# THRONE_WEBHOOK_SIGNED_MESSAGE_FORMAT=timestamp_dot_body
# Maximum allowed clock skew in seconds between Throne and this server. Default: 300.
# THRONE_WEBHOOK_MAX_TIMESTAMP_SKEW_SECONDS=300
# Set to true temporarily to log raw Throne webhook bodies plus parsed summaries to journalctl.
# THRONE_WEBHOOK_DEBUG_LOG_PAYLOAD=false

# Optional override for the JSON event config file.
# EVENTS_CONFIG_PATH=./config/events.json
