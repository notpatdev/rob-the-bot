DISCORD_TOKEN=
BOT_NAME=Rob
EVENT_NAME=Mother's Day Event

DATABASE_PATH=/opt/rob-the-bot/data/rob_the_bot.sqlite3

# --- Throne tracking (all optional) ---
# How often (seconds) to poll registered Dommes' Throne pages. Default: 60.
# THRONE_POLL_INTERVAL_SECONDS=60
# Delay between Domme requests within a cycle, to avoid hammering Throne. Default: 3.
# THRONE_POLL_PER_DOMME_DELAY_SECONDS=3
# Per-request HTTP timeout. Default: 10.
# THRONE_HTTP_TIMEOUT_SECONDS=10
# User-Agent header to send when scraping. Defaults to a benign realistic UA.
# THRONE_USER_AGENT=
